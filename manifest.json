{
  "manifest_version": 3,
  "name": "Copilot Usage Tracker",
  "version": "1.0.0",
  "description": "GitHub Copilot Premium Request 사용량 모니터링",

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Copilot Usage Tracker"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "tabs"
  ],

  "host_permissions": [
    "https://api.github.com/*",
    "https://gist.githubusercontent.com/*"
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
